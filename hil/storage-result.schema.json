{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/openbsw-rust/storage-result.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "fixture_id",
    "fixture_revision",
    "board",
    "probe_class",
    "artifact",
    "destructive_scope",
    "reset_safe",
    "cases",
    "outcome"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "fixture_id": {"type": "string", "pattern": "^fixture-[a-z0-9]{1,16}$"},
    "fixture_revision": {"const": "hil-fixture-v2"},
    "board": {"enum": ["stm32f413", "stm32g474"]},
    "probe_class": {"const": "st-link"},
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "sha256"],
      "properties": {
        "name": {"type": "string"},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "destructive_scope": {"const": "linker-reserved-storage-only"},
    "reset_safe": {"const": true},
    "cases": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "passed", "detail"],
        "properties": {
          "name": {"type": "string"},
          "passed": {"type": "boolean"},
          "detail": {"type": "string"}
        }
      }
    },
    "outcome": {"enum": ["passed", "failed"]}
  }
}
