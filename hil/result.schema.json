{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/openbsw-rust/hil-result.schema.json",
  "title": "OpenBSW deterministic HIL campaign result",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "fixture_id", "fixture_revision", "board", "probe_class", "can", "reset_method", "runs", "agreement", "outcome"],
  "properties": {
    "schema_version": {"const": 1},
    "fixture_id": {"$ref": "#/$defs/fixtureId"},
    "fixture_revision": {"type": "string", "pattern": "^hil-fixture-v[0-9]+$"},
    "board": {"$ref": "#/$defs/board"},
    "probe_class": {"const": "st-link"},
    "can": {
      "type": "object", "additionalProperties": false,
      "required": ["interface_class", "bitrate", "mode"],
      "properties": {
        "interface_class": {"const": "socketcan"},
        "bitrate": {"const": 500000},
        "mode": {"const": "classic"}
      }
    },
    "reset_method": {"const": "debug-port-system-reset"},
    "runs": {"type": "array", "minItems": 2, "items": {"$ref": "#/$defs/run"}},
    "agreement": {"type": "boolean"},
    "outcome": {"enum": ["passed", "failed"]}
  },
  "$defs": {
    "fixtureId": {"type": "string", "pattern": "^fixture-[a-z0-9]{1,16}$"},
    "board": {"enum": ["stm32f413", "stm32g474"]},
    "case": {
      "type": "object", "additionalProperties": false,
      "required": ["name", "passed", "duration_us", "detail"],
      "properties": {
        "name": {"type": "string"}, "passed": {"type": "boolean"},
        "duration_us": {"type": "integer", "minimum": 0}, "detail": {"type": "string"}
      }
    },
    "run": {
      "type": "object", "additionalProperties": false,
      "required": ["schema_version", "fixture_id", "board", "run_index", "artifact", "monotonic", "isolation", "cases", "outcome"],
      "properties": {
        "schema_version": {"const": 1}, "fixture_id": {"$ref": "#/$defs/fixtureId"},
        "board": {"$ref": "#/$defs/board"}, "run_index": {"type": "integer", "minimum": 1},
        "artifact": {
          "type": "object", "additionalProperties": false, "required": ["name", "sha256"],
          "properties": {"name": {"type": "string"}, "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}}
        },
        "monotonic": {
          "type": "object", "additionalProperties": false, "required": ["origin_ns", "finished_ns"],
          "properties": {"origin_ns": {"type": "integer", "minimum": 0}, "finished_ns": {"type": "integer", "minimum": 0}}
        },
        "isolation": {
          "type": "object", "additionalProperties": false,
          "required": ["fixture_lock", "peer_isolated", "can_reset", "serial_flushed", "noinit_cleared"],
          "properties": {
            "fixture_lock": {"const": true},
            "peer_isolated": {"const": true},
            "can_reset": {"const": true},
            "serial_flushed": {"const": true},
            "noinit_cleared": {"const": true}
          }
        },
        "cases": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/case"}},
        "outcome": {"enum": ["passed", "failed"]}
      }
    }
  }
}
